# Copy to .env (or just export these) to enable the optional LLM + higher rate limits.
# The pipeline runs fully WITHOUT either of these — they only improve it.

# Enables the Claude narrative stage (team/product/market/risks + market score).
# Without it, `analyze` uses the deterministic offline fallback.
ANTHROPIC_API_KEY=

# Optional: raises the GitHub API rate limit from 60/hr to 5000/hr (unauth still works).
GITHUB_TOKEN=
